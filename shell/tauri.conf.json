{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Booster Lander",
  "version": "0.1.0",
  "identifier": "com.boosterlander.sim",
  "build": {
    "beforeDevCommand": "pnpm -C ../ui dev",
    "devUrl": "http://127.0.0.1:5183",
    "beforeBuildCommand": "pnpm -C ../ui build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Booster Lander",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "//": "canon §11.1: allow the direct localhost WS to core --serve. WebGPU is",
      "//2": "default-on in WebView2 since 113 — no additionalBrowserArgs needed.",
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost ws://127.0.0.1:* http://127.0.0.1:*",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob:",
        "worker-src": "'self' blob:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "//": "canon §11.1: core ships as a sidecar. externalBin resolves relative to",
    "//2": "src-tauri/ (this dir); Tauri appends -$TARGET_TRIPLE, so the on-disk file",
    "//3": "is binaries/booster-core-x86_64-pc-windows-msvc.exe. CMake copies it here.",
    "externalBin": ["binaries/booster-core"]
  }
}
