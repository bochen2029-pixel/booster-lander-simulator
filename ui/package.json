  "dependencies": {
    "three": "0.185.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "@types/three": "0.185.0"
  }
}
