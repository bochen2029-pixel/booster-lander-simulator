{
  "name": "booster-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Booster Lander renderer — three.js r185 WebGPU, telemetry-honest observer (canon §11).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
